# Copy to .env and fill in. All client-side vars must be prefixed with VITE_.

# Base URL of the backend API (include the /api suffix).
# Defaults to the Render backend in production and http://localhost:3000/api locally.
VITE_API_BASE_URL=http://localhost:3000/api

# Optional explicit health-check origin (defaults derived from the API base URL).
# VITE_API_HEALTHCHECK_URL=http://localhost:3000

# Public origin used to build shareable links (no trailing slash).
VITE_PUBLIC_APP_URL=https://ignite-me.app

# ImgBB API key used for client-side image uploads.
# NOTE: this key ships in the client bundle. Rotate the previously committed key
# and treat this as a rate-limited, low-privilege key (ideally proxy uploads
# through the backend instead).
VITE_IMGBB_API_KEY=
